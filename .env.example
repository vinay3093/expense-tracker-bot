# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ─── LLM provider ─────────────────────────────────────────────────────────
# Which backend the bot talks to. Switching is just an env-var change —
# zero code changes upstream.
#
# Allowed values:
#   groq      Groq Cloud, free tier, OpenAI-compatible (default)
#   ollama    Local-only, runs on your laptop (offline-friendly)
#   openai    ChatGPT — paid, requires `pip install -e ".[openai]"`
#   anthropic Claude   — paid, requires `pip install -e ".[anthropic]"`
#   fake      In-memory stub for tests
LLM_PROVIDER=groq

# ─── Groq (https://console.groq.com/keys) ─────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ─── Ollama (https://ollama.com) ──────────────────────────────────────────
# Only used when LLM_PROVIDER=ollama. You must have `ollama serve` running
# and have pulled the model: `ollama pull llama3.1`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── OpenAI (https://platform.openai.com/api-keys) ────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic (https://console.anthropic.com/settings/keys) ──────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ─── Common LLM tunables ──────────────────────────────────────────────────
# Per-request timeout in seconds.
LLM_TIMEOUT_S=30.0
# Total attempts on retryable errors (rate-limit / 5xx / network). 1..10.
LLM_MAX_RETRIES=3
# 0.0..2.0 — extraction tasks want determinism, not creativity.
LLM_TEMPERATURE=0.1
# Soft cap on completion length.
LLM_MAX_TOKENS=1024

# ─── Locale (Step 3+) ─────────────────────────────────────────────────────
# Used to resolve "today" / "yesterday" / "last week" from YOUR local
# perspective rather than the server's. Any IANA name works.
#   Examples: America/Chicago, Asia/Kolkata, Europe/London, UTC
TIMEZONE=UTC
# ISO-4217 currency assumed when the user doesn't specify one.
DEFAULT_CURRENCY=INR
# Optional: path to a YAML file overriding the bundled category taxonomy
# (src/expense_tracker/extractor/data/categories.yaml). Step 4 will plug
# the real Google-Sheet column headers in here.
# EXTRACTOR_CATEGORIES_FILE=./config/categories.yaml

# ─── Storage / observability ──────────────────────────────────────────────
# When true, every LLM call is appended to logs/llm_calls.jsonl and every
# user turn (Step 3+) to logs/conversations.jsonl. Free debugging gold —
# only disable for raw benchmarking.
LLM_TRACE=true
# Where to write JSONL logs. Path is relative to the cwd you run the bot from.
LOG_DIR=./logs
# Storage backend for chat / trace history. Today: jsonl. SQLite/DuckDB
# can be swapped in later behind the same protocol with no code changes.
CHAT_STORE_BACKEND=jsonl

# ─── Google Sheets (Step 4) ───────────────────────────────────────────────
# Path to the service-account JSON file (this file MUST stay outside git).
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service-account.json
# The Google Sheet's ID (from its URL: docs.google.com/spreadsheets/d/<ID>/edit)
EXPENSE_SHEET_ID=

# ─── Telegram (Step 8) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
