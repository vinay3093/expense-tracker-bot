# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ─── LLM provider ─────────────────────────────────────────────────────────
# Which backend to use: "groq" (default, free tier, fast) or "ollama" (offline).
LLM_PROVIDER=groq

# Groq — sign up at https://console.groq.com/keys (free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama — only used when LLM_PROVIDER=ollama. Default URL works for local installs.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Google Sheets ────────────────────────────────────────────────────────
# Path to the service-account JSON file (this file MUST stay outside git).
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service-account.json

# The Google Sheet's ID (from its URL: docs.google.com/spreadsheets/d/<ID>/edit)
EXPENSE_SHEET_ID=

# ─── Telegram (added later) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
