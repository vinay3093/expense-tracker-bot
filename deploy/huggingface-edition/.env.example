# Local parity testing for the Hugging Face Spaces edition.
#
# Copy to `.env-hf-test` (which is gitignored — see /.gitignore),
# fill in real values, then test the same code path HF will run with:
#
#     docker build -t expense-bot:hf -f Dockerfile .
#     docker run --rm --env-file deploy/huggingface-edition/.env-hf-test \
#         -p 7860:7860 expense-bot:hf
#
# In another terminal:
#     curl http://localhost:7860/health   # → ok
#     # then DM your bot on Telegram
#
# When happy, paste the same values into Hugging Face → Space →
# Settings → Secrets.

# ─── LLM ───────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_REPLACE_ME

# ─── Sheets ────────────────────────────────────────────────────────────
EXPENSE_SHEET_ID=REPLACE_WITH_LONG_TOKEN_FROM_SHEET_URL

# Paste the FULL contents of secrets/service-account.json here, on
# ONE line, escaped properly.  Easiest way:
#     python -c 'import json; print(json.dumps(open("secrets/service-account.json").read()))'
# then paste the output (with the surrounding quotes) below.
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account",...REPLACE_ME...}

# ─── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_ALLOWED_USERS=REPLACE_WITH_YOUR_TELEGRAM_USER_ID

# ─── Locale ────────────────────────────────────────────────────────────
TIMEZONE=America/Chicago
DEFAULT_CURRENCY=USD

# ─── HF / docker port (don't change unless you know why) ───────────────
TELEGRAM_HEALTH_PORT=7860
